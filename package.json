{
  "name": "expo-camera-image-picker",
  "version": "1.2.0",
  "description": "Custom camera modal and picker controls for Expo apps using react-native-vision-camera",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build/**/*",
    "src/**/*"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Abappi19 <abappi19@gmail.com> (https://abappi19.github.io)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abappi19/expo-camera-image-picker.git"
  },
  "bugs": {
    "url": "https://github.com/abappi19/expo-camera-image-picker/issues"
  },
  "homepage": "https://github.com/abappi19/expo-camera-image-picker#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "yarn@1.22.22",
  "keywords": [
    "react-native",
    "expo",
    "expo-camera-image-picker",
    "camera",
    "image-picker",
    "vision-camera",
    "react-native-vision-camera",
    "ios",
    "android"
  ],
  "scripts": {
    "build": "expo-module build",
    "lint": "expo-module lint -- --fix",
    "format": "eslint src --fix",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "run:ios": "cd example && expo run:ios",
    "run:android": "cd example && expo run:android",
    "prepare": "EXPO_NONINTERACTIVE=1 expo-module build && husky",
    "commit": "commit",
    "release": "changeset",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "release:add": "changeset add",
    "release:status": "changeset status",
    "release:tag": "changeset tag"
  },
  "eslintConfig": {
    "extends": "universe/native"
  },
  "peerDependencies": {
    "expo": ">=55.0.0",
    "expo-device": ">=55.0.0",
    "expo-image-picker": ">=17.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.83.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-svg": ">=15.0.0",
    "react-native-vision-camera": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/cz-commitlint": "^19.5.0",
    "@commitlint/prompt-cli": "^19.5.0",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.12.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "8",
    "eslint-config-universe": "^13.0.0",
    "expo": "^55.0.8",
    "expo-device": "~55.0.10",
    "expo-image-picker": "~55.0.14",
    "expo-module-scripts": "^3.0.5",
    "expo-modules-core": "~55.0.18",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-vision-camera": "^4.7.3",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@changesets/changelog-git": "^0.2.1"
  }
}
